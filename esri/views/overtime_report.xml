<odoo>
    <data>

        <!-- ─── Add overtime & deduction columns to the attendance_ids list ─── -->
        <record model="ir.ui.view" id="hr_leave_attendance_report_view_form_attendance_ids_cols">
            <field name="name">hr.leave.attendance.report.form.attendance.ids.cols</field>
            <field name="model">hr.leave.attendance.report</field>
            <field name="inherit_id" ref="hr_holidays_attendance.hr_leave_attendance_report_view_form"/>
            <field name="arch" type="xml">

                <!--
                    NOTE: this targets the embedded list inside the
                    attendance_ids One2many field. If the upgrade fails
                    with an xpath error, open the base view in Technical
                    Settings and check the actual structure of the
                    attendance_ids field's inline <list>/<tree> (some
                    versions use <tree>, others <list>).
                -->
                <!-- Add total deduction below the Difference field -->
                <xpath expr="//field[@name='difference_hours']" position="after">
                    <field name="total_deduction_hours" widget="float_time" readonly="1" string="Deduction Hours"/>
                </xpath>

                <xpath expr="//field[@name='attendance_ids']/list" position="inside">
                    <!-- Overtime fields -->
                    <field name="over_time_worked_hours" widget="float_time"/>
<!--                    <field name="overtime_hours_before_sunset" widget="float_time" optional="hide"/>-->
<!--                    <field name="overtime_hours_after_sunset" widget="float_time" optional="hide"/>-->
<!--                    <field name="weighted_overtime_before_sunset" widget="float_time" optional="hide"/>-->
<!--                    <field name="weighted_overtime_after_sunset" widget="float_time" optional="hide"/>-->
                    <field name="total_overtime_hours" widget="float_time"/>

                    <!-- Deduction field -->
                    <field name="deduction_hours" widget="float_time"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>