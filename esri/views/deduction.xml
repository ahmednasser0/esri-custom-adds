<odoo>
    <data>

        <!-- ─── Form View ─────────────────────────────────────────────────── -->
        <record model="ir.ui.view" id="deduction_form_view">
            <field name="name">deduction.form</field>
            <field name="model">deduction</field>
            <field name="arch" type="xml">
                <form string="Deduction">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="date"/>
                                <field name="type" readonly="1"/>
                                <field name="is_absent"/>
                            </group>
                            <group>
                                <field name="day_overtime"  widget="float_time" readonly="1"/>
                                <field name="day_deduction" widget="float_time" readonly="1"/>
                                <field name="weekly_deduction_hours" widget="float_time" readonly="1"/>
                                <field name="allocation_before" readonly="1"/>
                                <field name="allocation_after"  readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ─── Search View ───────────────────────────────────────────────── -->
        <record model="ir.ui.view" id="deduction_search_view">
            <field name="name">deduction.search</field>
            <field name="model">deduction</field>
            <field name="arch" type="xml">
                <search string="Deductions">
                    <field name="name"/>
                    <field name="date"/>
                    <separator/>
                    <filter name="filter_overtime"
                            string="Overtime"
                            domain="[('type', '=', 'overtime')]"/>
                    <filter name="filter_deduction"
                            string="Deduction"
                            domain="[('type', '=', 'deduction')]"/>
                    <filter name="filter_overtime_deduction"
                            string="Overtime and Deduction"
                            domain="[('type', '=', 'overtime_deduction')]"/>
                    <separator/>
                    <filter name="group_by_employee"
                            string="Employee"
                            context="{'group_by': 'name'}"/>
                    <filter name="group_by_type"
                            string="Type"
                            context="{'group_by': 'type'}"/>
                </search>
            </field>
        </record>

        <!-- ─── List View ─────────────────────────────────────────────────── -->
        <record model="ir.ui.view" id="deduction_list_view">
            <field name="name">deduction.list</field>
            <field name="model">deduction</field>
            <field name="arch" type="xml">
                <list string="Deductions">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="type"/>
                </list>
            </field>
        </record>

        <!-- ─── Action ────────────────────────────────────────────────────── -->
        <record id="deduction_action" model="ir.actions.act_window">
            <field name="name">Deduction</field>
            <field name="res_model">deduction</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No Deductions Created
                </p>
            </field>
        </record>

        <!-- ─── Menu Item ──────────────────────────────────────────────────── -->
        <menuitem
            name="Advanced Allocation"
            id="attendance_deduction"
            parent="hr_attendance.menu_hr_attendance_root"
            action="deduction_action"
            sequence="10"/>

        <!-- ─── Cron: weekly part-time deduction (runs every Friday) ────────── -->
        <record id="ir_cron_parttime_deduction" model="ir.cron">
            <field name="name">HR: Create Part-Time Weekly Deductions</field>
            <field name="model_id" ref="esri.model_deduction"/>
            <field name="state">code</field>
            <field name="code">model._cron_create_parttime_deductions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="active">True</field>
        </record>


</data>
</odoo>