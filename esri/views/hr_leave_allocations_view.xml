<odoo>
    <data>

        <!-- ─── Add money_deduction_hours to the Manager Allocation form ───── -->
        <record model="ir.ui.view" id="hr_leave_allocation_view_form_manager_money_deduction">
            <field name="name">hr.leave.allocation.form.manager.money.deduction</field>
            <field name="model">hr.leave.allocation</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_form_manager"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='number_of_days_display']" position="after">
                    <field name="date_from"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>